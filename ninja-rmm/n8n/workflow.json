{
  "name": "NinjaRMM Maintenance Monitor (Read-Only)",
  "nodes": [
    {
      "parameters": {"rule": "*/15 * * * *"},
      "id": "1",
      "name": "Cron",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 1,
      "position": [120, 300]
    },
    {
      "parameters": {
        "values": {
          "string": [
            {"name": "NINJA_CLIENT_ID", "value": ""},
            {"name": "NINJA_CLIENT_SECRET", "value": ""},
            {"name": "NINJA_INSTANCE", "value": "pundit.rmmservice.com"},
            {"name": "ORG_ID", "value": ""},
            {"name": "WINDOW_START", "value": "2026-02-24T23:30:00Z"},
            {"name": "WINDOW_END", "value": "2026-02-25T01:00:00Z"},
            {"name": "LINK_BASE", "value": "https://pundit.rmmservice.com/#/deviceDashboard"},
            {"name": "NOTIFY_EMAIL", "value": "wledrew@pund-it.ca"}
          ]
        }
      },
      "id": "2",
      "name": "Set Config",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [300, 300]
    },
    {
      "parameters": {"functionCode": "// Keep config nested\nreturn [{ json: { config: $json } }];"},
      "id": "3",
      "name": "Store Config",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [480, 220]
    },
    {
      "parameters": {
        "authentication": "none",
        "requestMethod": "POST",
        "url": "https://{{$json[\"NINJA_INSTANCE\"]}}/oauth/token",
        "jsonParameters": false,
        "options": {"sendBodyAs": "form", "responseFormat": "json"},
        "bodyParametersUi": {"parameter": [
          {"name": "grant_type", "value": "client_credentials"},
          {"name": "client_id", "value": "={{$json[\"NINJA_CLIENT_ID\"]}}"},
          {"name": "client_secret", "value": "={{$json[\"NINJA_CLIENT_SECRET\"]}}"},
          {"name": "scope", "value": "monitoring"}
        ]}
      },
      "id": "4",
      "name": "Get Token",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [480, 380]
    },
    {
      "parameters": {"mode": "passThrough", "propertyName": "token"},
      "id": "5",
      "name": "Merge Config + Token",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 2,
      "position": [660, 300]
    },
    {
      "parameters": {
        "authentication": "none",
        "requestMethod": "GET",
        "url": "https://{{$json.config.NINJA_INSTANCE}}/v2/organization/{{$json.config.ORG_ID}}/devices?pageSize=1000",
        "jsonParameters": true,
        "headerParametersJson": "{\n  \"Authorization\": \"Bearer {{$json.token.access_token}}\"\n}"
      },
      "id": "6",
      "name": "List Devices",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [840, 300]
    },
    {
      "parameters": {
        "functionCode": "const devices = $json.results || $json.devices || $json;\nconst servers = (Array.isArray(devices) ? devices : []).filter(d => (d.nodeClass||'').includes('WINDOWS_SERVER'));\nreturn servers.map(d => ({ json: { config: $json.config, token: $json.token, deviceId: d.id, deviceName: d.systemName || 'Unknown', nodeClass: d.nodeClass }}));"
      },
      "id": "7",
      "name": "Filter Servers",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [1020, 300]
    },
    {
      "parameters": {
        "authentication": "none",
        "requestMethod": "GET",
        "url": "https://{{$json.config.NINJA_INSTANCE}}/v2/device/{{$json.deviceId}}/activities?pageSize=200",
        "jsonParameters": true,
        "headerParametersJson": "{\n  \"Authorization\": \"Bearer {{$json.token.access_token}}\"\n}"
      },
      "id": "8",
      "name": "Fetch Activities",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [1200, 300]
    },
    {
      "parameters": {
        "functionCode": "const start = new Date($json.config.WINDOW_START).getTime() / 1000;\nconst end = new Date($json.config.WINDOW_END).getTime() / 1000;\nconst acts = $json.activities || [];\nconst inWindow = acts.filter(a => (a.activityTime||0) >= start && (a.activityTime||0) <= end);\nconst hasReboot = inWindow.some(a => a.statusCode === 'SYSTEM_REBOOTED' || (/System rebooted/i).test(a.message||''));\nconst patchIssues = inWindow.filter(a => (a.activityResult === 'FAILURE') || (/FAILED|ERROR/i).test(a.statusCode||'') || (/download error|failed|blocked/i).test(a.message||''));\nconst postScan = inWindow.some(a => (/post reboot scan is required/i).test(a.message||''));\nif (!hasReboot && patchIssues.length === 0 && !postScan) { return []; }\nconst linkBase = $json.config.LINK_BASE || '';\nreturn [{ json: {
  deviceId: $json.deviceId,
  deviceName: $json.deviceName,
  rebooted: hasReboot,
  patchIssues: patchIssues.length,
  postRebootScanRequired: postScan,
  link: linkBase ? `${linkBase}/${$json.deviceId}/overview` : '',
  windowStart: $json.config.WINDOW_START,
  windowEnd: $json.config.WINDOW_END,
  notifyEmail: $json.config.NOTIFY_EMAIL
}}];"
      },
      "id": "9",
      "name": "Filter Alerts",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [1380, 300]
    },
    {
      "parameters": {
        "functionCode": "const key = `${$json.windowStart}|${$json.deviceId}`;\nconst store = this.getWorkflowStaticData('global');\nif (store[key]) { return []; }\nstore[key] = true;\nreturn [{ json: $json }];"
      },
      "id": "10",
      "name": "Dedupe",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [1560, 300]
    },
    {
      "parameters": {
        "fromEmail": "monitor@example.com",
        "toEmail": "={{$json.notifyEmail}}",
        "subject": "NinjaRMM Maintenance Alert: {{$json.deviceName}}",
        "text": "Device: {{$json.deviceName}} (ID {{$json.deviceId}})\nRebooted: {{$json.rebooted}}\nPatch issues: {{$json.patchIssues}}\nPost-reboot scan required: {{$json.postRebootScanRequired}}\nLink: {{$json.link}}\nWindow: {{$json.windowStart}} to {{$json.windowEnd}}"
      },
      "id": "11",
      "name": "Email Alert",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2,
      "position": [1740, 300]
    }
  ],
  "connections": {
    "1": {"main": [[{"node": "2", "type": "main", "index": 0}]]},
    "2": {"main": [[{"node": "3", "type": "main", "index": 0}, {"node": "4", "type": "main", "index": 0}]]},
    "3": {"main": [[{"node": "5", "type": "main", "index": 0}]]},
    "4": {"main": [[{"node": "5", "type": "main", "index": 1}]]},
    "5": {"main": [[{"node": "6", "type": "main", "index": 0}]]},
    "6": {"main": [[{"node": "7", "type": "main", "index": 0}]]},
    "7": {"main": [[{"node": "8", "type": "main", "index": 0}]]},
    "8": {"main": [[{"node": "9", "type": "main", "index": 0}]]},
    "9": {"main": [[{"node": "10", "type": "main", "index": 0}]]},
    "10": {"main": [[{"node": "11", "type": "main", "index": 0}]]}
  },
  "active": false,
  "settings": {},
  "staticData": {},
  "pinData": {},
  "id": "1"
}
